  "private": true,
  "engines": {
    "node": ">=22.14.0 < 23.0.0"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "gulp bundle",
    "clean": "gulp clean",
    "test": "jest --config ./config/jest.config.json",
    "test:watch": "jest --config ./config/jest.config.json --watchAll",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:setup": "playwright test --project=setup --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:screenshots": "playwright test appsource-screenshots",
    "test:e2e:fullpage": "playwright test full-page-screenshots",
    "assets:appsource": "python store-assets/scripts/build-appsource-real.py",
    "assets:embed-brand": "python store-assets/scripts/embed-marketing-brand.py"
  },
  "dependencies": {
    "@fluentui/react": "^8.106.4",
