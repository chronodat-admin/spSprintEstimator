{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": "../src",
  "testMatch": ["**/*.test.ts"],
  "moduleFileExtensions": ["ts", "tsx", "js"],
  "transform": {
    "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "<rootDir>/../config/tsconfig.test.json" }]
  },
  "moduleNameMapper": {
    "\\.(css|scss)$": "identity-obj-proxy",
    "\\.(png|jpg|gif)$": "<rootDir>/test/__mocks__/fileMock.js"
  },
  "collectCoverageFrom": [
    "services/SessionEngine.ts",
    "services/sessionTypeStrategies.ts",
    "utils/codeGenerator.ts"
  ],
  "coverageThreshold": {
    "./src/services/SessionEngine.ts": {
      "branches": 70,
      "functions": 80,
      "lines": 80,
      "statements": 80
    },
    "./src/services/sessionTypeStrategies.ts": {
      "branches": 65,
      "functions": 80,
      "lines": 80,
      "statements": 80
    }
  }
}
